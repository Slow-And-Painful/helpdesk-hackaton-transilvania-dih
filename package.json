{
  "name": "hackaton-tdih",
  "version": "1.0.0",
  "main": "src/index.ts",
  "engines": {
    "node": ">=22",
    "npm": ">=9"
  },
  "scripts": {
    "server:dev": "nodemon",
    "dev": "./dev.sh",
    "makemigrations": "drizzle-kit generate",
    "dropmigration": "drizzle-kit drop",
    "custommigration": "drizzle-kit generate --custom",
    "start": "node --enable-source-maps dist/index.js",
    "xss:scan": "xss-scan",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "tsx -r dotenv/config scripts/build.ts",
    "pre:build": "./scripts/prebuild.sh",
    "prepare": "husky",
    "db:seed": "npm run db:command -- --environment=local --command=seed",
    "db:drop": "npm run db:command -- --environment=local --command=drop",
    "db:truncate": "npm run db:command -- --environment=local --command=truncate",
    "db:reset": "npm run db:command -- --environment=local --command=reset",
    "db:reseed": "npm run db:command -- --environment=local --command=reseed",
    "migrate": "npm run db:command -- --environment=local --command=migrate",
    "db:command": "node --import tsx -r dotenv/config -r reflect-metadata scripts/db_command",
    "assets:types": "node --import tsx scripts/assets_types.ts",
    "generate:templates-enum": "node --import tsx -r dotenv/config -r reflect-metadata scripts/generate-mail-templates-enum",
    "upload:email": "node --import tsx -r dotenv/config -r reflect-metadata scripts/upload-local-email-templates",
    "lambda:dev": "local-lambda",
    "studio": "drizzle-kit studio"
  },
  "keywords": [
    "eslint",
    "typescript",
    "nodemon",
    "husky"
  ],
  "author": "Polarity <info@polarity.dev>",
  "license": "ISC",
  "description": "",
